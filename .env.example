# Copie para .env e ajuste se necessário: cp .env.example .env
# Usado pelo docker compose e por scripts locais.

# DynamoDB Local (docker compose)
DYNAMODB_PORT=8000
DYNAMODB_ENDPOINT=http://localhost:8000
TABLE_NAME=flow-table
AWS_REGION=us-east-1

# Ledger-service (quando rodar com perfil local)
# Quarkus usa essas variáveis se definidas (application-local.properties pode referenciar)
# QUARKUS_DYNAMODB_ENDPOINT_OVERRIDE=http://localhost:8000
# QUARKUS_DYNAMODB_TABLE_NAME=flow-table

# Frontend (flow-app) - apiUrl já está em src/environments/environment.ts como http://localhost:8081
# Para outro host/porta, edite flow-app/src/environments/environment.ts
