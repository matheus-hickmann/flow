{
  "name": "flow-app",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:all": "concurrently -n d,t,a,r,s \"ng serve dashboard\" \"ng serve transactions\" \"ng serve accounts\" \"ng serve reports\" \"ng serve flow-app\"",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@softarc/native-federation-node": "^3.3.4",
    "chart.js": "^4.5.1",
    "es-module-shims": "^1.5.12",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-architects/native-federation": "^21.1.1",
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular/build": "^21.1.3",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@playwright/test": "^1.59.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.9.0"
  }
